        </div>
        <div class="col-sm-3 well">            
            @if (cache.Get("positions") != null)
            {
                <b>Current Positions</b>
                <table class="table">
                    @* <tr>
                        <th>Planet</th>
                        <th>House</th>
                    </tr> *@
                    @foreach (var item in cache.GetC<List<Positions>>("positions"))
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Planet)
                                @Html.DisplayFor(modelItem => item.retro)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.sign)
                            </td>
                        </tr>
                    }
                </table>
            }
            else
            {
                 <div class="thumbnail">
                <p>Upcoming Events:</p>
                <img src="images\paris.jpg" alt="Paris" width="400" height="300">
                <p><strong>Paris</strong></p>
                <p>Fri. 27 November 2015</p>
                <button class="btn btn-primary">Info</button>
